---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';

const principles = [
  {
    n: '01',
    title: 'Safety first',
    body: 'Slip and fall issues — pendulum slip testing, and clear recommendations.',
  },
  {
    n: '02',
    title: 'Restoration second',
    body: 'Strip, clean, restore. Our highly trained teams bring your floors back to life and restore the safety levels your customers, patients, students and staff need.',
  },
  {
    n: '03',
    title: 'One contractor is all you need',
    body: 'Survey, test, treat and re-test — start to finish, with one team.',
  },
  {
    n: '04',
    title: 'Plain English',
    body: 'No jargon, no upsell. Just results and peace of mind.',
  },
];
---

<Layout
  title="About — Floor Restoration & Slip-Safety Specialists | SaniSafe Solutions"
  description="SaniSafe Solutions is an Ennis-based floor restoration and slip-safety company working across Ireland. We treat all types of floors in all types of settings."
>
  <Hero
    eyebrow="About SaniSafe Solutions"
    headline="Restoration is the craft. Safety is the reason to call."
    subhead="We are an Ennis-based floor restoration and slip-safety company, working across Ireland. We treat all types of floors in all types of settings."
    variant="navy"
    imageKey="about"
  >
    <a slot="ctas" href="/contact" class="btn-primary">Request a quote</a>
    <a slot="ctas" href="/services/sliptest" class="btn-yellow-outline">Book a SlipTest survey</a>
  </Hero>

  {/* ---------- HOW WE WORK ---------- */}
  <Section variant="white">
    <div class="max-w-2xl">
      <p class="eyebrow">How we work</p>
      <h2 class="h-section mt-3">Four key principles.</h2>
    </div>

    <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {principles.map((p) => (
        <li class="card p-6 h-full flex flex-col">
          <span class="font-display font-extrabold text-4xl text-brand-blue">{p.n}</span>
          <h3 class="mt-3 font-display font-extrabold text-lg text-brand-navy">{p.title}</h3>
          <p class="mt-2 text-ink-slate">{p.body}</p>
        </li>
      ))}
    </ol>
  </Section>

  <CTA />
</Layout>
