---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import { images } from '../data/images';

const values = [
  { title: 'Safety first', body: 'We lead with slip-risk reduction. Pendulum readings before and after — defensible, in numbers.' },
  { title: 'Restoration second', body: 'Strip and re-pour is rarely necessary. We work the floor you have back to a standard you can live with.' },
  { title: 'One contractor', body: 'Survey, test, treat and re-test under one roof. One number, one paper trail, one invoice.' },
  { title: 'Plain English', body: 'No jargon, no upsell. If a re-coat is enough we will tell you.' },
];
---

<Layout
  title="About — Ennis-based, working across Ireland | SaniSafe Solutions"
  description="SaniSafe Solutions is an Ennis-based floor restoration and slip-safety company working nationwide. Restoration is the craft. Safety is the reason to call."
>
  <Hero
    eyebrow="About SaniSafe Solutions"
    headline="Restoration is the craft. Safety is the reason to call."
    subhead="We are an Ennis-based floor restoration and slip-safety company, working across Ireland. We treat slip resistance as the headline outcome — restoration is what we do to get there."
    variant="navy"
    imageKey="about"
  >
    <a slot="ctas" href="/contact" class="btn-primary">Request a quote</a>
    <a slot="ctas" href="/services/sliptest" class="btn-yellow-outline">Book a SlipTest survey</a>
  </Hero>

  <Section variant="white">
    <div class="grid gap-10 lg:grid-cols-12 items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow">Where we are</p>
        <h2 class="h-section mt-3">Based in Ennis. Working nationwide.</h2>
        <p class="lead mt-4">
          We are based in Ennis, Co. Clare, and we work across Ireland — from Munster and the west to Dublin, the
          midlands and the north-west. Most jobs are programmed around your trading hours.
        </p>
        <p class="prose-body mt-4">
          {/* TODO: real founder bio + photo */}
          Our team brings together experienced floor restoration specialists and slip-safety practitioners. We carry
          our own pendulum equipment and we keep one contractor on a job from first visit through re-test — so
          nothing falls between two contractors.
        </p>
      </div>
      <div class="lg:col-span-6">
        <div class="overflow-hidden rounded-xl shadow-card">
          <img
            src={images.about.src}
            alt={images.about.alt}
            width={images.about.width}
            height={images.about.height}
            loading="lazy"
            class="block h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </Section>

  <Section variant="offwhite">
    <p class="eyebrow">How we work</p>
    <h2 class="h-section mt-3">Four things we hold to.</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {values.map((v) => (
        <div class="card p-6 h-full">
          <h3 class="font-display font-extrabold text-lg text-brand-navy">{v.title}</h3>
          <p class="mt-2 text-ink-slate">{v.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section variant="white">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="eyebrow">Insurance & H&S</p>
        <h2 class="h-section mt-3">Documentation, when you need it.</h2>
      </div>
      <div class="lg:col-span-7 prose-body space-y-4 max-w-prose">
        <p>
          {/* TODO: confirm insurance details with client */}
          We carry public liability and employers' liability insurance, with documentation available on request. RAMS
          are produced for every site and shared with your H&S contact before we mobilise.
        </p>
        <p>
          Our pendulum reports reference HSA guidance and follow the same protocol used by HSE (UK) — so a report
          produced here stands up to scrutiny in either jurisdiction.
        </p>
      </div>
    </div>
  </Section>

  <CTA />
</Layout>
