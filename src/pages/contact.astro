---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';

const sent = Astro.url.searchParams.get('sent') === 'true';
---

<Layout
  title="Contact SaniSafe Solutions — Quotes within 24 hours | Ireland"
  description="Get in touch with SaniSafe Solutions for floor restoration, anti-slip treatments and pendulum slip testing. Based in Ennis, working nationwide. Quotes within 24 hours."
>
  <Hero
    eyebrow="Get in touch"
    headline="Tell us about the floor."
    subhead="Send the details and we will come back to you within one working day. Site visits in Munster, Connacht, Leinster and Ulster — wherever the floor is, we will travel."
    variant="navy"
    imageKey="hero"
  >
    <a slot="ctas" href={`mailto:${site.email}`} class="btn-secondary">{site.email}</a>
    <a slot="ctas" href={site.phoneHref} class="btn-secondary">{site.phoneDisplay}</a>
  </Hero>

  <Section variant="white">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        {sent && (
          <div role="status" class="mb-6 rounded-md border border-brand-green/40 bg-brand-green/10 px-4 py-3 text-brand-navy">
            <p class="font-semibold">Thanks — we have your enquiry.</p>
            <p class="text-sm">We will be in touch within one working day.</p>
          </div>
        )}
        <p class="eyebrow">Enquiry form</p>
        <h2 class="h-section mt-3">Quote within 24 hours.</h2>
        <p class="prose-body mt-3 max-w-prose">
          The more you tell us about the floor — surface, area, use of the space, any safety concerns — the more
          specific our reply can be. If you would rather not use the form, the email and phone are above.
        </p>
        <div class="mt-8 max-w-2xl">
          <ContactForm />
        </div>
      </div>

      <aside class="lg:col-span-5 grid gap-6 content-start">
        <div class="card p-6">
          <h3 class="font-display font-extrabold text-lg text-brand-navy">Where we are</h3>
          <p class="mt-2 text-ink-slate">
            {/* TODO: real street address */}
            {site.location.streetAddressDisplay}
          </p>
        </div>
        <div class="card p-6">
          <h3 class="font-display font-extrabold text-lg text-brand-navy">Direct contact</h3>
          <ul class="mt-2 grid gap-1 text-base">
            <li><a class="text-brand-navy hover:underline" href={`mailto:${site.email}`}>{site.email}</a></li>
            <li><a class="text-brand-navy hover:underline" href={site.phoneHref}>{site.phoneDisplay}</a></li>
          </ul>
        </div>
        <div class="card p-6">
          <h3 class="font-display font-extrabold text-lg text-brand-navy">Hours</h3>
          <p class="mt-2 text-ink-slate">{site.hours}</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display font-extrabold text-lg text-brand-navy">Service area</h3>
          <p class="mt-2 text-ink-slate">All of Ireland. Site visits arranged in advance.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display font-extrabold text-lg text-brand-navy">Company</h3>
          <p class="mt-2 text-ink-slate text-sm">SaniSafe Solutions</p>
          {/* TODO: replace placeholder with real CRO number once issued */}
          <p class="mt-3"><span class="cro-placeholder">{site.croDisplay}</span></p>
        </div>
      </aside>
    </div>
  </Section>
</Layout>
