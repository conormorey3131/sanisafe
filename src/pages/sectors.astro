---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import { images } from '../data/images';
import { work, type WorkKey } from '../data/work';

type SectorBlock = {
  slug: string;
  title: string;
  intro: string;
  imageKey: keyof typeof images;
  bullets: string[];
  audience: string;
  /** Optional before/after proof shot — key into src/data/work.ts. */
  work?: WorkKey;
};

const sectorBlocks: SectorBlock[] = [
  {
    slug: 'hospital-and-healthcare',
    title: 'Hospital & Healthcare',
    intro:
      'Hospitals, primary-care centres, nursing homes and dental practices. These floors demand the highest standards of hygiene and floor safety.',
    imageKey: 'sectorHospital',
    bullets: [
      'Restoration and deep cleaning of vinyl, ceramic and marmoleum floors — all common in healthcare settings.',
      'Anti-slip treatments that survive frequent wet cleaning.',
      'Documented PTV per zone for H&S, infection-control and insurance files.',
    ],
    audience:
      'Operations managers, infection-control managers and H&S officers in HSE, voluntary, private and primary-care settings.',
    work: 'greenClinicFloor',
  },
  {
    slug: 'commercial',
    title: 'Commercial — hotels, retail, offices, leisure & schools',
    intro:
      'Customer-facing floors that have to look the part and stay safe under high-volume foot traffic, spills and frequent cleaning. Trading and opening hours sensitive.',
    imageKey: 'sectorCommercial',
    bullets: [
      'Hotels: lobby marble, tile and porcelain restoration, pool-surround cleaning, limescale removal and anti-slip treatments.',
      'Retail: travertine, wood and stone floors restored outside of trading hours.',
      'Offices: floor restoration with minimal disruption.',
      'Leisure centres and schools: changing-room floors, pool decks, classrooms and hallways.',
    ],
    audience:
      'Operations managers, facilities managers, general managers and school management.',
    work: 'yellowSchoolFloor',
  },
  {
    slug: 'domestic',
    title: 'Domestic',
    intro:
      'Marble lobbies, hardwood living areas, travertine and tiled kitchens, tiled bathrooms — the same standard of work we apply on commercial sites, at a price that makes sense for a home.',
    imageKey: 'sectorDomestic',
    bullets: [
      'Restoration of marble, hardwood and tiled floors without replacing the floor.',
      'Anti-slip treatments for bathrooms, hallways and wet rooms.',
      'Clean, low-dust and low-odour working methods in occupied homes.',
    ],
    audience: 'Homeowners and interior architects across Ireland.',
    work: 'marbleBathroom',
  },
];
---

<Layout
  title="Sectors — Hospital, Commercial & Domestic Floor Restoration | SaniSafe Solutions"
  description="SaniSafe Solutions works across hospitals & healthcare, commercial settings (hotels, retail, offices, leisure, schools) and domestic homes. Restoration, anti-slip treatments and pendulum slip testing."
>
  <Hero
    eyebrow="Sectors we serve"
    headline="A constant standard, with three different briefs."
    subhead="The way a floor is used changes the brief. Compliance and infection control drive healthcare facilities. Trading hours, customer inconvenience and brand preservation drive our commercial customers. Care and value for money drive domestic customers."
    variant="navy"
    imageKey="sectorCommercial"
  >
    <a slot="ctas" href="/contact" class="btn-primary">Request a quote</a>
  </Hero>

  {sectorBlocks.map((s, idx) => {
    const img = images[s.imageKey];
    const variant = idx % 2 === 0 ? 'white' : 'offwhite';
    const reverse = idx % 2 === 1;
    return (
      <Section variant={variant} id={s.slug}>
        <div class={`grid gap-10 lg:grid-cols-12 items-center ${reverse ? 'lg:[&>:first-child]:order-2' : ''}`}>
          <div class="lg:col-span-6">
            <div class="overflow-hidden rounded-xl shadow-card">
              <img
                src={img.src}
                alt={img.alt}
                width={img.width}
                height={img.height}
                loading="lazy"
                class="block h-full w-full object-cover"
              />
            </div>
          </div>
          <div class="lg:col-span-6">
            <p class="eyebrow">Sector</p>
            <h2 class="h-section mt-3">{s.title}</h2>
            <p class="lead mt-4">{s.intro}</p>
            <ul class="mt-6 grid gap-3 text-base text-ink-charcoal">
              {s.bullets.map((b) => (
                <li class="flex gap-3">
                  <span aria-hidden="true" class="mt-1 inline-block h-2.5 w-2.5 rounded-full bg-brand-green"></span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <p class="mt-5 text-sm text-ink-slate"><strong class="text-brand-navy">Who we talk to:</strong> {s.audience}</p>
            {s.work && (
              <figure class="mt-6 overflow-hidden rounded-xl border border-surface-grey bg-white">
                <div class="relative">
                  <img
                    src={work[s.work].src}
                    alt={work[s.work].alt}
                    loading="lazy"
                    decoding="async"
                    class="block w-full h-auto"
                  />
                  <span class="absolute left-3 top-3 rounded-full bg-brand-navy/85 px-3 py-1 text-[0.7rem] font-bold uppercase tracking-[0.12em] text-white backdrop-blur-sm">
                    Before / After
                  </span>
                </div>
                <figcaption class="px-4 py-3 text-sm text-ink-slate">{work[s.work].caption}</figcaption>
              </figure>
            )}
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/contact" class="btn-primary">Request a quote</a>
              <a href="/services/sliptest" class="btn-secondary">Pendulum slip test</a>
            </div>
          </div>
        </div>
      </Section>
    );
  })}

  <CTA />
</Layout>
