---
import Layout from '../layouts/Layout.astro';
import Section from './Section.astro';
import Hero from './Hero.astro';
import CTA from './CTA.astro';
import type { ServiceContent } from '../data/serviceContent';

export interface Props {
  content: ServiceContent;
}
const { content } = Astro.props;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: content.title,
  provider: { '@type': 'LocalBusiness', name: 'SaniSafe Solutions', areaServed: 'IE' },
  areaServed: 'IE',
  description: content.metaDescription,
});

const faqLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

<Layout title={content.metaTitle} description={content.metaDescription} jsonLd={[jsonLd, faqLd]}>
  <Hero
    eyebrow={content.heroEyebrow}
    headline={content.heroHeadline}
    subhead={content.heroSubhead}
    variant={content.heroVariant}
    imageKey={content.heroImageKey}
  >
    <a slot="ctas" href="/contact" class="btn-primary">Request a quote</a>
    <a slot="ctas" href="/services/sliptest" class="btn-secondary">Pendulum slip test</a>
  </Hero>

  {/* What we do */}
  <Section variant="white">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="eyebrow">What we do</p>
        <h2 class="h-section mt-3">{content.heroPromise}</h2>
      </div>
      <div class="lg:col-span-7">
        <ul class="grid gap-3 text-base text-ink-charcoal">
          {content.whatWeDo.map((b) => (
            <li class="flex gap-3">
              <span aria-hidden="true" class="mt-1 inline-block h-2.5 w-2.5 rounded-full bg-brand-green"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  {/* Where it's used */}
  <Section variant="offwhite">
    <p class="eyebrow">Where it's used</p>
    <h2 class="h-section mt-3">Sectors we work in.</h2>
    <div class="mt-6 flex flex-wrap gap-3">
      {content.whereUsed.map((s) => (
        <a href={s.href} class="chip">{s.label}</a>
      ))}
    </div>
  </Section>

  {/* How it works */}
  <Section variant="white">
    <p class="eyebrow">How it works</p>
    <h2 class="h-section mt-3">A clear sequence, on every job.</h2>
    <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {content.howItWorks.map((step, idx) => (
        <li class="card p-6 h-full flex flex-col">
          <span class="font-display font-extrabold text-4xl text-brand-blue">
            {String(idx + 1).padStart(2, '0')}
          </span>
          <h3 class="mt-3 font-display font-extrabold text-lg text-brand-navy">{step.title}</h3>
          <p class="mt-2 text-ink-slate">{step.body}</p>
        </li>
      ))}
    </ol>
  </Section>

  {/* FAQ */}
  <Section variant="white">
    <p class="eyebrow">FAQ</p>
    <h2 class="h-section mt-3">Plain-English answers.</h2>
    <div class="mt-8 grid gap-4 max-w-3xl">
      {content.faqs.map((f) => (
        <details class="group rounded-lg border border-surface-grey bg-white open:shadow-card">
          <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 font-semibold text-brand-navy">
            <span>{f.q}</span>
            <svg aria-hidden="true" viewBox="0 0 20 20" class="h-5 w-5 transition-transform group-open:rotate-180"><path fill="currentColor" d="M5 8l5 5 5-5z"/></svg>
          </summary>
          <div class="px-5 pb-5 text-ink-slate">{f.a}</div>
        </details>
      ))}
    </div>
  </Section>

  <CTA />
</Layout>
