---
import { services, site } from '../data/site';
export interface Props {
  /** Show full service-of-interest dropdown */
  detailed?: boolean;
}
const { detailed = true } = Astro.props;
---

<form id="contact-form" class="grid gap-5">
  {/* Web3Forms delivery — posts straight to the inbox tied to the access key */}
  <input type="hidden" name="access_key" value={site.web3formsAccessKey} />
  <input type="hidden" name="subject" value="New website enquiry — SaniSafe Solutions" />
  <input type="hidden" name="from_name" value="SaniSafe Solutions website" />
  {/* Honeypot — bots tick this, humans never see it */}
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <p id="contact-status" hidden></p>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="name" class="block text-sm font-semibold text-brand-navy">Name <span aria-hidden="true" class="text-brand-blue">*</span></label>
      <input
        id="name" name="name" type="text" required autocomplete="name"
        class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-semibold text-brand-navy">Email <span aria-hidden="true" class="text-brand-blue">*</span></label>
      <input
        id="email" name="email" type="email" required autocomplete="email"
        class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
      />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="phone" class="block text-sm font-semibold text-brand-navy">Phone <span aria-hidden="true" class="text-brand-blue">*</span></label>
      <input
        id="phone" name="phone" type="tel" required autocomplete="tel" inputmode="tel"
        class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
      />
    </div>
    <div>
      <label for="company" class="block text-sm font-semibold text-brand-navy">Company / Site</label>
      <input
        id="company" name="company" type="text" autocomplete="organization"
        class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
      />
    </div>
  </div>

  <div>
    <label for="address" class="block text-sm font-semibold text-brand-navy">Address / site location</label>
    <input
      id="address" name="address" type="text" autocomplete="street-address"
      placeholder="Street, town, county / Eircode"
      class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
    />
  </div>

  {detailed && (
    <div>
      <label for="service" class="block text-sm font-semibold text-brand-navy">Service of interest</label>
      <select
        id="service" name="service"
        class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
      >
        <option value="">— Choose one —</option>
        {services.map((s) => (
          <option value={s.title}>{s.title}</option>
        ))}
        <option value="Other / not sure">Other / not sure</option>
      </select>
    </div>
  )}

  <div>
    <label for="message" class="block text-sm font-semibold text-brand-navy">Tell us about the floor <span aria-hidden="true" class="text-brand-blue">*</span></label>
    <textarea
      id="message" name="message" rows="5" required
      placeholder="Surface type, approximate area, any safety concerns, deadlines."
      class="mt-2 w-full rounded-md border border-surface-grey bg-white px-3 py-2.5 text-base text-ink-charcoal focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/30"
    ></textarea>
    <p class="mt-2 text-sm text-ink-slate">
      Got photos of the floor? They really help us quote.
      <a class="font-semibold text-brand-navy underline" href={`mailto:${site.email}?subject=${encodeURIComponent('Floor photos — enquiry')}`}>Email them to {site.email}</a>
      and we'll match them to your enquiry.
    </p>
  </div>

  <div class="flex flex-wrap items-center gap-4 pt-2">
    <button type="submit" class="btn-primary">Send enquiry</button>
    <a href={`mailto:${site.email}`} class="text-sm font-semibold text-brand-navy hover:underline">
      Or email {site.email} directly
    </a>
  </div>
  <p class="text-xs text-ink-slate">
    We'll only use these details to reply to your enquiry. By submitting you agree to our
    <a class="underline" href="/privacy">privacy notice</a>.
  </p>
</form>

<script define:vars={{ endpoint: 'https://api.web3forms.com/submit', accessKey: site.web3formsAccessKey, email: site.email }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-status');
  const PLACEHOLDER = 'YOUR_WEB3FORMS_ACCESS_KEY';

  function setStatus(message, ok) {
    if (!status) return;
    status.textContent = message;
    status.hidden = false;
    status.className =
      'rounded-md px-4 py-3 text-sm ' +
      (ok
        ? 'border border-brand-green/40 bg-brand-green/10 text-brand-navy'
        : 'border border-red-300 bg-red-50 text-red-800');
    status.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;

    const data = new FormData(form);
    const service = (data.get('service') || '').toString().trim();
    data.set('subject', service ? `Website enquiry — ${service}` : 'Website enquiry — SaniSafe Solutions');

    // Fallback while no access key is configured: open the visitor's email app.
    if (!accessKey || accessKey === PLACEHOLDER) {
      const value = (key) => (data.get(key) || '').toString().trim();
      const body = [
        `Name: ${value('name')}`,
        `Email: ${value('email')}`,
        value('phone') && `Phone: ${value('phone')}`,
        value('company') && `Company / Site: ${value('company')}`,
        value('address') && `Address: ${value('address')}`,
        service && `Service of interest: ${service}`,
        '',
        value('message'),
      ]
        .filter(Boolean)
        .join('\n');
      window.location.href = `mailto:${email}?subject=${encodeURIComponent(
        data.get('subject'),
      )}&body=${encodeURIComponent(body)}`;
      return;
    }

    const button = form.querySelector('button[type="submit"]');
    const original = button ? button.textContent : '';
    if (button) {
      button.disabled = true;
      button.textContent = 'Sending…';
    }

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      const result = await response.json();
      if (result.success) {
        form.reset();
        setStatus('Thanks — we have your enquiry and will be in touch within one working day.', true);
      } else {
        setStatus(`Sorry, that didn't send. Please email ${email} directly.`, false);
      }
    } catch (err) {
      setStatus(`Could not send right now. Please email ${email} directly.`, false);
    } finally {
      if (button) {
        button.disabled = false;
        button.textContent = original;
      }
    }
  });
</script>
