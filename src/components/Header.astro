---
import { nav, site } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 lg:static w-full bg-white/95 backdrop-blur border-b border-surface-grey">
  <div class="container-page flex items-center justify-between gap-4 py-2">
    <a href="/" class="flex items-center gap-4">
      <img
        src="/logo.jpeg"
        alt="SaniSafe Solutions"
        width="288"
        height="288"
        class="h-28 w-28 sm:h-32 sm:w-32 lg:h-36 lg:w-36 rounded-md object-contain bg-white"
      />
      <span class="hidden md:flex flex-col leading-tight">
        <span class="font-display font-extrabold text-brand-navy text-2xl lg:text-3xl">SaniSafe Solutions</span>
        <span class="text-sm uppercase tracking-[0.18em] text-brand-navy font-bold">Floor restoration &amp; slip safety</span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden lg:flex items-center gap-1">
      {nav.map((item) => (
        item.children ? (
          <div class="relative group">
            <a
              href={item.href}
              class:list={[
                'inline-flex items-center gap-1 px-3 py-2 rounded-md font-semibold text-ink-charcoal hover:text-brand-navy hover:bg-surface-offwhite',
                isActive(item.href) && 'text-brand-navy',
              ]}
              aria-haspopup="true"
            >
              {item.label}
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4"><path fill="currentColor" d="M5.5 7.5 10 12l4.5-4.5"/></svg>
            </a>
            <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 focus-within:visible focus-within:opacity-100 transition absolute left-0 top-full pt-2 w-72">
              <ul class="bg-white border border-surface-grey rounded-md shadow-card overflow-hidden py-2">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2 text-sm text-ink-charcoal hover:bg-surface-offwhite hover:text-brand-navy',
                        isActive(child.href) && 'bg-surface-offwhite text-brand-navy',
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-md font-semibold text-ink-charcoal hover:text-brand-navy hover:bg-surface-offwhite',
              isActive(item.href) && 'text-brand-navy',
            ]}
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/contact" class="hidden md:inline-flex btn-primary text-sm py-2.5 px-4">Get a quote</a>
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-md border border-surface-grey text-brand-navy"
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-nav-toggle
        aria-label="Open menu"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" hidden class="lg:hidden border-t border-surface-grey bg-white">
    <nav aria-label="Mobile" class="container-page py-3 grid gap-1">
      {nav.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 rounded-md font-semibold text-ink-charcoal hover:bg-surface-offwhite',
              isActive(item.href) && 'text-brand-navy bg-surface-offwhite',
            ]}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="pl-3 grid gap-0.5 pb-1">
              {item.children.map((child) => (
                <a href={child.href} class="block px-3 py-1.5 text-sm text-ink-slate hover:text-brand-navy hover:bg-surface-offwhite rounded">
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <a href="/contact" class="btn-primary mt-2">Get a quote</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.getElementById('mobile-nav');
  if (btn && panel) {
    btn.addEventListener('click', () => {
      const open = panel.hasAttribute('hidden') ? false : true;
      if (open) {
        panel.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Open menu');
      } else {
        panel.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
        btn.setAttribute('aria-label', 'Close menu');
      }
    });
  }
</script>
