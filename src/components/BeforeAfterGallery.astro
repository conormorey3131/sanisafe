---
import type { WorkItem } from '../data/work';

export interface Props {
  items: WorkItem[];
  /** Max columns at the largest breakpoint (2 or 3). */
  columns?: 2 | 3;
}

const { items, columns = 3 } = Astro.props;

// Masonry via CSS columns so portrait collages and landscape pairs sit tidily
// together without being cropped.
const colClass = columns === 3 ? 'sm:columns-2 lg:columns-3' : 'sm:columns-2';
---

<div class:list={['columns-1 gap-6', colClass]}>
  {items.map((item) => (
    <figure class="mb-6 break-inside-avoid card overflow-hidden">
      <div class="relative">
        <img
          src={item.src}
          alt={item.alt}
          loading="lazy"
          decoding="async"
          class="block w-full h-auto"
        />
        <span class="absolute left-3 top-3 rounded-full bg-brand-navy/85 px-3 py-1 text-[0.7rem] font-bold uppercase tracking-[0.12em] text-white backdrop-blur-sm">
          Before / After
        </span>
      </div>
      <figcaption class="p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-brand-blue">{item.tag}</p>
        <p class="mt-1 font-medium text-ink-charcoal">{item.caption}</p>
      </figcaption>
    </figure>
  ))}
</div>
